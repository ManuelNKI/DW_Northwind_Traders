                <component
                  refId="Package\Poblar Tablas de Hechos\Poblar Fact_Inventario\Origen DW"
                  componentClassID="Microsoft.OLEDBSource"
                  contactInfo="OLE DB Source;Microsoft Corporation; Microsoft SQL Server; (C) Microsoft Corporation; All Rights Reserved; http://www.microsoft.com/sql/support;7"
                  description="OLE DB Source"
                  name="Origen DW"
                  usesDispositions="true"
                  version="7">
                  <properties>
                    <property
                      dataType="System.Int32"
                      description="The number of seconds before a command times out.  A value of 0 indicates an infinite time-out."
                      name="CommandTimeout">0</property>
                    <property
                      dataType="System.String"
                      description="Specifies the name of the database object used to open a rowset."
                      name="OpenRowset"></property>
                    <property
                      dataType="System.String"
                      description="Specifies the variable that contains the name of the database object used to open a rowset."
                      name="OpenRowsetVariable"></property>
                    <property
                      dataType="System.String"
                      description="The SQL command to be executed."
                      name="SqlCommand"
                      UITypeEditor="Microsoft.DataTransformationServices.Controls.ModalMultilineStringEditor">SELECT 
    -- 1. Llave de Fecha (Generamos la fecha de HOY en formato YYYYMMDD)
    YEAR(GETDATE()) * 10000 + MONTH(GETDATE()) * 100 + DAY(GETDATE()) AS Fecha_ID,
    
    -- 2. Llave del Producto (Desde tu DW)
    dp.Producto_ID,
    
    -- 3. Métricas de Inventario (Desde el OLTP)
    ISNULL(p.UnitsInStock, 0) AS Stock,
    
    -- Cálculo del dinero estancado
    CAST((ISNULL(p.UnitsInStock, 0) * ISNULL(p.UnitPrice, 0)) AS DECIMAL(18,2)) AS Capital_Inmovilizado,
    
    ISNULL(p.ReorderLevel, 0) AS Nivel_Reorden,
    ISNULL(p.UnitsOnOrder, 0) AS Unidades_En_Transito,
    
    -- 4. Cálculo Avanzado: Días de Inactividad (Días desde su última venta)
    ISNULL(DATEDIFF(day, 
        (SELECT MAX(o.OrderDate) 
         FROM [Northwind].[dbo].[Order Details] od 
         INNER JOIN [Northwind].[dbo].[Orders] o ON od.OrderID = o.OrderID
         WHERE od.ProductID = p.ProductID), 
        GETDATE()
    ), 0) AS Dias_Inactividad

FROM [Northwind].[dbo].[Products] p

-- Cruzamos directamente con la Dimensión Producto de tu Data Warehouse
INNER JOIN [DW_Northwind_Traders].[dbo].[Dim_Producto] dp 
    ON p.ProductName = dp.Producto;</property>
