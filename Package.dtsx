    <DTS:Executable
      DTS:refId="Package\Poblar Dim_Fecha"
      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:Description="Execute SQL Task"
      DTS:DTSID="{591D7749-E66A-471A-A5CA-4DDC1ADC19FE}"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:LocaleID="-1"
      DTS:ObjectName="Poblar Dim_Fecha"
      DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2025; © 2025 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
      DTS:ThreadHint="1">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{298B49D8-6FEC-4DB7-A214-0650AC73F558}"
          SQLTask:SqlStatementSource="DECLARE @FechaInicio DATE = '1990-01-01';&#xA;DECLARE @FechaFin DATE = '2030-12-31';&#xA;DECLARE @FechaActual DATE = @FechaInicio;&#xA;&#xA;-- Evitar que el script muestre mensajes de &quot;1 row affected&quot; por cada día (son miles)&#xA;SET NOCOUNT ON; &#xA;&#xA;WHILE @FechaActual &lt;= @FechaFin&#xA;BEGIN&#xA;    INSERT INTO DW_Northwind_Traders.dbo.Dim_Fecha &#xA;    (&#xA;        Fecha_ID, &#xA;        Dia, &#xA;        Mes, &#xA;        Trimestre, &#xA;        Año&#xA;    )&#xA;    VALUES &#xA;    (&#xA;        -- Genera el ID formato YYYYMMDD (Ej: 19960704)&#xA;        YEAR(@FechaActual) * 10000 + MONTH(@FechaActual) * 100 + DAY(@FechaActual),&#xA;        DAY(@FechaActual),&#xA;        MONTH(@FechaActual),&#xA;        DATEPART(QUARTER, @FechaActual),&#xA;        YEAR(@FechaActual)&#xA;    );&#xA;&#xA;    -- Avanzar al siguiente día&#xA;    SET @FechaActual = DATEADD(DAY, 1, @FechaActual);&#xA;END;&#xA;&#xA;SET NOCOUNT OFF;" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
