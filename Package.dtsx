                <component
                  refId="Package\Poblar Tablas de Hechos\Poblar Fact_Ventas\Origen DW"
                  componentClassID="Microsoft.OLEDBSource"
                  contactInfo="OLE DB Source;Microsoft Corporation; Microsoft SQL Server; (C) Microsoft Corporation; All Rights Reserved; http://www.microsoft.com/sql/support;7"
                  description="OLE DB Source"
                  name="Origen DW"
                  usesDispositions="true"
                  version="7">
                  <properties>
                    <property
                      dataType="System.Int32"
                      description="The number of seconds before a command times out.  A value of 0 indicates an infinite time-out."
                      name="CommandTimeout">0</property>
                    <property
                      dataType="System.String"
                      description="Specifies the name of the database object used to open a rowset."
                      name="OpenRowset"></property>
                    <property
                      dataType="System.String"
                      description="Specifies the variable that contains the name of the database object used to open a rowset."
                      name="OpenRowsetVariable"></property>
                    <property
                      dataType="System.String"
                      description="The SQL command to be executed."
                      name="SqlCommand"
                      UITypeEditor="Microsoft.DataTransformationServices.Controls.ModalMultilineStringEditor">SELECT 
    od.OrderID AS Numero_Orden,
    dc.Cliente_ID,      -- Llave subrogada directa del DW
    de.Empleado_ID,     -- Llave subrogada directa del DW
    dp.Producto_ID,     -- Llave subrogada directa del DW
    
    -- Transformación de fecha a INT (YYYYMMDD)
    YEAR(o.OrderDate) * 10000 + MONTH(o.OrderDate) * 100 + DAY(o.OrderDate) AS Fecha_ID,
    
    od.Quantity AS Cantidad,
    
    -- Cálculos financieros
    CAST((od.Quantity * od.UnitPrice) AS DECIMAL(18,2)) AS Ingreso_Bruto,
    CAST((od.Quantity * od.UnitPrice * od.Discount) AS DECIMAL(18,2)) AS Monto_Descontado,
    CAST(((od.Quantity * od.UnitPrice) - (od.Quantity * od.UnitPrice * od.Discount)) AS DECIMAL(18,2)) AS Ingreso_Neto

FROM [Northwind].[dbo].[Orders] o
INNER JOIN [Northwind].[dbo].[Order Details] od 
    ON o.OrderID = od.OrderID

-- 1. Traemos los datos descriptivos del OLTP (Northwind)
INNER JOIN [Northwind].[dbo].[Customers] c 
    ON o.CustomerID = c.CustomerID
INNER JOIN [Northwind].[dbo].[Employees] e 
    ON o.EmployeeID = e.EmployeeID
INNER JOIN [Northwind].[dbo].[Products] p 
    ON od.ProductID = p.ProductID

-- 2. Cruzamos directamente con las Dimensiones de tu Data Warehouse
INNER JOIN [DW_Northwind_Traders].[dbo].[Dim_Cliente] dc 
    ON c.CompanyName = dc.Compania
INNER JOIN [DW_Northwind_Traders].[dbo].[Dim_Empleado] de 
    ON (e.FirstName + ' ' + e.LastName) = de.Empleado
INNER JOIN [DW_Northwind_Traders].[dbo].[Dim_Producto] dp 
    ON p.ProductName = dp.Producto;</property>
