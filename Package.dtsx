                <component
                  refId="Package\Poblar Tablas de Hechos\Poblar Fact_Logistica\Origen DW"
                  componentClassID="Microsoft.OLEDBSource"
                  contactInfo="OLE DB Source;Microsoft Corporation; Microsoft SQL Server; (C) Microsoft Corporation; All Rights Reserved; http://www.microsoft.com/sql/support;7"
                  description="OLE DB Source"
                  name="Origen DW"
                  usesDispositions="true"
                  version="7">
                  <properties>
                    <property
                      dataType="System.Int32"
                      description="The number of seconds before a command times out.  A value of 0 indicates an infinite time-out."
                      name="CommandTimeout">0</property>
                    <property
                      dataType="System.String"
                      description="Specifies the name of the database object used to open a rowset."
                      name="OpenRowset"></property>
                    <property
                      dataType="System.String"
                      description="Specifies the variable that contains the name of the database object used to open a rowset."
                      name="OpenRowsetVariable"></property>
                    <property
                      dataType="System.String"
                      description="The SQL command to be executed."
                      name="SqlCommand"
                      UITypeEditor="Microsoft.DataTransformationServices.Controls.ModalMultilineStringEditor">SELECT 
    -- 1. Métricas Financieras y Tiempos (Hechos)
    CAST(ISNULL(o.Freight, 0) AS DECIMAL(18,2)) AS Costo_Flete,
    
    -- Días de preparación: Diferencia entre la orden y el envío.
    -- (Si aún no se envía, ponemos 0 temporalmente)
    ISNULL(DATEDIFF(day, o.OrderDate, o.ShippedDate), 0) AS Dias_Preparacion,
    
-- Días de retraso estrictos (Si se adelantó o llegó a tiempo, pone 0. Si llegó tarde, pone los días de mora)
ISNULL(CASE 
    WHEN DATEDIFF(day, o.RequiredDate, o.ShippedDate) &lt; 0 THEN 0 
    ELSE DATEDIFF(day, o.RequiredDate, o.ShippedDate) 
END, 0) AS Dias_Retraso,
    
    -- 2. Llaves de Tiempo (Role-Playing Dimensions)
    YEAR(o.OrderDate) * 10000 + MONTH(o.OrderDate) * 100 + DAY(o.OrderDate) AS Fecha_Orden_ID,
    
    YEAR(o.RequiredDate) * 10000 + MONTH(o.RequiredDate) * 100 + DAY(o.RequiredDate) AS Fecha_Requerida_ID,

    -- Manejo del Nulo en la Fecha de Envío (Si no se ha enviado, ponemos -1 o una fecha "falsa" controlada)
    ISNULL(YEAR(o.ShippedDate) * 10000 + MONTH(o.ShippedDate) * 100 + DAY(o.ShippedDate), -1) AS Fecha_Envio_ID,
    
    -- 3. Llaves de Dimensiones (Desde tu DW)
    dce.Compania_Envio_ID,
    dc.Cliente_ID

FROM [Northwind].[dbo].[Orders] o

-- 1. Traemos los nombres desde el OLTP (Usamos LEFT JOIN en Shippers por si hay pedidos sin transportista asignado)
LEFT JOIN [Northwind].[dbo].[Shippers] s ON o.ShipVia = s.ShipperID
INNER JOIN [Northwind].[dbo].[Customers] c ON o.CustomerID = c.CustomerID

-- 2. Cruzamos directamente con las Dimensiones de tu Data Warehouse
LEFT JOIN [DW_Northwind_Traders].[dbo].[Dim_Compania_Envio] dce 
    ON s.CompanyName = dce.Compania_Envio
INNER JOIN [DW_Northwind_Traders].[dbo].[Dim_Cliente] dc 
    ON c.CompanyName = dc.Compania;</property>
